#!/usr/bin/python3
"""Launcher for Bodhi Update Manager.

This script is installed at /usr/bin/bodhi-update-manager by the Debian
package.  It prepends the application tree to sys.path so that the
bodhi_update package is importable without modifying site-packages, then
delegates to the real application entry point.
"""

import os
import sys

# Make the application package tree importable.
sys.path.insert(0, "/usr/lib/bodhi-update-manager")

# Remove the broken xapp GTK module from the environment if present.
# Some Bodhi setups export GTK3_MODULES=xapp-gtk3-module even when the
# module is not installed, causing GTK warnings on startup.
_val = os.environ.get("GTK3_MODULES")
if _val:
    _parts = [m for m in _val.split(":") if m and m != "xapp-gtk3-module"]
    if _parts:
        os.environ["GTK3_MODULES"] = ":".join(_parts)
    else:
        os.environ.pop("GTK3_MODULES", None)

import gi                          # noqa: E402
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk      # noqa: E402

from bodhi_update.app import main  # noqa: E402

Gtk.Window.set_default_icon_name("bodhi-update-manager")
main()
